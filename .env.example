# Copy this file to ".env" and fill in your keys.

# The brain (required unless you run fully local — see JARVIS_BRAIN below).
ANTHROPIC_API_KEY=sk-ant-...

# Speech-to-text. Deepgram (cloud) OR local Whisper (set JARVIS_STT_ENGINE=whisper).
DEEPGRAM_API_KEY=...

# Spotify play-by-name (create an app at developer.spotify.com/dashboard).
SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- optional toggles (sensible defaults; override only if you want) ---
# JARVIS_BRAIN=auto        # auto (Claude + local fallback) | claude | local
# JARVIS_STT_ENGINE=deepgram   # deepgram | whisper (local, offline)
# JARVIS_WHISPER_MODEL=base.en
# JARVIS_LOCAL_MODEL=qwen2.5:7b   # needs Ollama installed
# JARVIS_VOICE=              # blank = auto-pick best installed macOS voice
